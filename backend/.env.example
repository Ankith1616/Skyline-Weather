# Port configuration
PORT=5000

# MongoDB URI (default local database)
MONGO_URI=mongodb://127.0.0.1:27017/weather_app

# OpenWeatherMap API Key
# If left empty or set to "mock", the backend will automatically return high-fidelity mock weather data.
# Get a real API Key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=mock

# Node environment configuration (development, production)
NODE_ENV=development
